# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="mysql://assetflow:assetflow123@localhost:3306/assetflow"

# JWT
JWT_SECRET=assetflow-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=assetflow-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Client URL
CLIENT_URL=http://localhost:5173

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@assetflow.com

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
