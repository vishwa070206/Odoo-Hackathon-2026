generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ROLES ─────────────────────────────────────────────
model Role {
  id        String   @id @default(uuid())
  name      String   @unique // ADMIN, ASSET_MANAGER, DEPARTMENT_HEAD, EMPLOYEE
  label     String   // Display label
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@map("roles")
}

// ─── USERS ─────────────────────────────────────────────
model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  password            String
  firstName           String
  lastName            String
  phone               String?
  avatar              String?
  employeeId          String?   @unique
  roleId              String
  departmentId        String?
  managerId           String?
  isEmailVerified     Boolean   @default(false)
  emailVerifyToken    String?
  resetPasswordToken  String?
  resetPasswordExpiry DateTime?
  refreshToken        String?   @db.Text
  lastLoginAt         DateTime?
  status              String    @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  isDeleted           Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  createdBy           String?

  role       Role        @relation(fields: [roleId], references: [id])
  department Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])
  manager    User?       @relation("ManagerReports", fields: [managerId], references: [id])
  reports    User[]      @relation("ManagerReports")

  // Relations
  allocationsReceived Allocation[]         @relation("AllocationEmployee")
  allocationsCreated  Allocation[]         @relation("AllocationCreator")
  transfersRequested  Transfer[]           @relation("TransferRequester")
  transfersApproved   Transfer[]           @relation("TransferApprover")
  bookings            Booking[]
  maintenanceRaised   MaintenanceRequest[] @relation("MaintenanceRequester")
  maintenanceAssigned MaintenanceRequest[] @relation("MaintenanceTechnician")
  auditAssignments    AuditAssignment[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  returnsProcessed    Return[]
  departmentsHeaded   Department[]         @relation("DepartmentHead")
  assetsCreated       Asset[]              @relation("AssetCreator")
  auditCyclesCreated  AuditCycle[]

  @@index([email])
  @@index([roleId])
  @@index([departmentId])
  @@map("users")
}

// ─── DEPARTMENTS ───────────────────────────────────────
model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?  @db.Text
  parentId    String?
  headId      String?
  status      String   @default("ACTIVE")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")
  head     User?        @relation("DepartmentHead", fields: [headId], references: [id])

  members     User[]       @relation("DepartmentMembers")
  assets      Asset[]
  allocations Allocation[]
  auditCycles AuditCycle[]

  @@map("departments")
}

// ─── ASSET CATEGORIES ──────────────────────────────────
model AssetCategory {
  id           String  @id @default(uuid())
  name         String  @unique
  description  String? @db.Text
  icon         String?
  parentId     String?
  customFields Json?   // Dynamic fields like warranty, brand, vendor
  status       String  @default("ACTIVE")
  isDeleted    Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?

  parent   AssetCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children AssetCategory[] @relation("CategoryHierarchy")
  assets   Asset[]

  @@map("asset_categories")
}

// ─── ASSETS ────────────────────────────────────────────
model Asset {
  id              String   @id @default(uuid())
  assetTag        String   @unique // AF-0001
  name            String
  description     String?  @db.Text
  categoryId      String
  departmentId    String?
  serialNumber    String?  @unique
  purchaseDate    DateTime?
  acquisitionCost Decimal? @db.Decimal(12, 2)
  condition       String   @default("NEW") // NEW, GOOD, FAIR, POOR
  location        String?
  warrantyExpiry  DateTime?
  brand           String?
  model           String?
  vendor          String?
  qrCode          String?  @db.Text
  barcode         String?
  isBookable      Boolean  @default(false)
  isShared        Boolean  @default(false)
  lifecycleStatus String   @default("AVAILABLE")
  // AVAILABLE, ALLOCATED, RESERVED, MAINTENANCE, LOST, RETIRED, DISPOSED
  expectedLife    Int?     // months
  notes           String?  @db.Text
  status          String   @default("ACTIVE")
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?

  category   AssetCategory @relation(fields: [categoryId], references: [id])
  department Department?   @relation(fields: [departmentId], references: [id])
  creator    User?         @relation("AssetCreator", fields: [createdBy], references: [id])

  photos              AssetPhoto[]
  documents           AssetDocument[]
  history             AssetHistory[]
  allocations         Allocation[]
  transfersFrom       Transfer[]           @relation("TransferFromAsset")
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]
  discrepancies       DiscrepancyReport[]

  @@index([assetTag])
  @@index([categoryId])
  @@index([lifecycleStatus])
  @@map("assets")
}

// ─── ASSET PHOTOS ──────────────────────────────────────
model AssetPhoto {
  id        String   @id @default(uuid())
  assetId   String
  url       String
  caption   String?
  isPrimary Boolean  @default(false)
  status    String   @default("ACTIVE")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  asset Asset @relation(fields: [assetId], references: [id])

  @@map("asset_photos")
}

// ─── ASSET DOCUMENTS ───────────────────────────────────
model AssetDocument {
  id        String   @id @default(uuid())
  assetId   String
  name      String
  type      String   // WARRANTY, INVOICE, MANUAL, OTHER
  url       String
  size      Int?
  status    String   @default("ACTIVE")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  asset Asset @relation(fields: [assetId], references: [id])

  @@map("asset_documents")
}

// ─── ASSET HISTORY ─────────────────────────────────────
model AssetHistory {
  id          String   @id @default(uuid())
  assetId     String
  action      String   // CREATED, ALLOCATED, TRANSFERRED, RETURNED, MAINTENANCE, AUDITED, etc.
  description String?  @db.Text
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  performedBy String?
  status      String   @default("ACTIVE")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@map("asset_history")
}

// ─── ALLOCATIONS ───────────────────────────────────────
model Allocation {
  id                 String    @id @default(uuid())
  assetId            String
  employeeId         String
  departmentId       String?
  allocatedDate      DateTime  @default(now())
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  notes              String?   @db.Text
  allocationStatus   String    @default("ACTIVE")
  // ACTIVE, RETURNED, OVERDUE, TRANSFERRED
  status             String    @default("ACTIVE")
  isDeleted          Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          String?

  asset      Asset       @relation(fields: [assetId], references: [id])
  employee   User        @relation("AllocationEmployee", fields: [employeeId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  creator    User?       @relation("AllocationCreator", fields: [createdBy], references: [id])
  returns    Return[]
  transfers  Transfer[]

  @@index([assetId])
  @@index([employeeId])
  @@map("allocations")
}

// ─── TRANSFERS ─────────────────────────────────────────
model Transfer {
  id               String    @id @default(uuid())
  assetId          String
  allocationId     String?
  fromDepartmentId String?
  toDepartmentId   String?
  fromUserId       String?
  toUserId         String?
  requestedBy      String
  approvedBy       String?
  reason           String?   @db.Text
  transferStatus   String    @default("PENDING")
  // PENDING, DEPT_HEAD_APPROVED, APPROVED, REJECTED, COMPLETED
  approvedDate     DateTime?
  completedDate    DateTime?
  status           String    @default("ACTIVE")
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdBy        String?

  asset      Asset       @relation("TransferFromAsset", fields: [assetId], references: [id])
  allocation Allocation? @relation(fields: [allocationId], references: [id])
  requester  User        @relation("TransferRequester", fields: [requestedBy], references: [id])
  approver   User?       @relation("TransferApprover", fields: [approvedBy], references: [id])

  @@index([assetId])
  @@map("transfers")
}

// ─── RETURNS ───────────────────────────────────────────
model Return {
  id           String   @id @default(uuid())
  allocationId String
  returnDate   DateTime @default(now())
  condition    String   // GOOD, FAIR, POOR, DAMAGED
  notes        String?  @db.Text
  images       Json?    // Array of image URLs
  processedBy  String?
  status       String   @default("ACTIVE")
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?

  allocation  Allocation @relation(fields: [allocationId], references: [id])
  processedByUser User?  @relation(fields: [processedBy], references: [id])

  @@map("returns")
}

// ─── BOOKINGS ──────────────────────────────────────────
model Booking {
  id            String    @id @default(uuid())
  assetId       String
  bookedBy      String
  title         String
  description   String?   @db.Text
  startTime     DateTime
  endTime       DateTime
  bookingStatus String    @default("UPCOMING")
  // UPCOMING, ONGOING, COMPLETED, CANCELLED
  cancelReason  String?   @db.Text
  status        String    @default("ACTIVE")
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     String?

  asset Asset @relation(fields: [assetId], references: [id])
  user  User  @relation(fields: [bookedBy], references: [id])

  @@index([assetId])
  @@index([startTime, endTime])
  @@map("bookings")
}

// ─── MAINTENANCE REQUESTS ──────────────────────────────
model MaintenanceRequest {
  id           String    @id @default(uuid())
  assetId      String
  requestedBy  String
  assignedTo   String?
  priority     String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  issueType    String?   // REPAIR, INSPECTION, REPLACEMENT, CALIBRATION
  title        String
  description  String    @db.Text
  photos       Json?     // Array of photo URLs
  resolution   String?   @db.Text
  cost         Decimal?  @db.Decimal(12, 2)
  workflowStatus String  @default("PENDING")
  // PENDING, APPROVED, REJECTED, ASSIGNED, IN_PROGRESS, RESOLVED
  approvedDate DateTime?
  resolvedDate DateTime?
  status       String    @default("ACTIVE")
  isDeleted    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?

  asset      Asset @relation(fields: [assetId], references: [id])
  requester  User  @relation("MaintenanceRequester", fields: [requestedBy], references: [id])
  technician User? @relation("MaintenanceTechnician", fields: [assignedTo], references: [id])

  history MaintenanceHistory[]

  @@index([assetId])
  @@map("maintenance_requests")
}

// ─── MAINTENANCE HISTORY ───────────────────────────────
model MaintenanceHistory {
  id          String   @id @default(uuid())
  requestId   String
  action      String   // STATUS_CHANGE, NOTE_ADDED, TECHNICIAN_ASSIGNED, etc.
  description String?  @db.Text
  oldValue    String?
  newValue    String?
  performedBy String?
  status      String   @default("ACTIVE")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  request MaintenanceRequest @relation(fields: [requestId], references: [id])

  @@map("maintenance_history")
}

// ─── AUDIT CYCLES ──────────────────────────────────────
model AuditCycle {
  id           String    @id @default(uuid())
  name         String
  description  String?   @db.Text
  departmentId String?
  location     String?
  startDate    DateTime
  endDate      DateTime?
  cycleStatus  String    @default("OPEN")
  // OPEN, IN_PROGRESS, COMPLETED, CLOSED
  isLocked     Boolean   @default(false)
  status       String    @default("ACTIVE")
  isDeleted    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?

  department   Department?       @relation(fields: [departmentId], references: [id])
  creator      User?             @relation(fields: [createdBy], references: [id])
  assignments  AuditAssignment[]
  discrepancies DiscrepancyReport[]

  @@map("audit_cycles")
}

// ─── AUDIT ASSIGNMENTS ─────────────────────────────────
model AuditAssignment {
  id        String   @id @default(uuid())
  cycleId   String
  auditorId String
  scope     String?  // Area or category to audit
  status    String   @default("ACTIVE")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  cycle   AuditCycle @relation(fields: [cycleId], references: [id])
  auditor User       @relation(fields: [auditorId], references: [id])
  items   AuditItem[]

  @@map("audit_assignments")
}

// ─── AUDIT ITEMS ───────────────────────────────────────
model AuditItem {
  id             String   @id @default(uuid())
  assignmentId   String
  assetId        String
  verificationStatus String @default("PENDING")
  // PENDING, VERIFIED, MISSING, DAMAGED
  notes          String?  @db.Text
  verifiedAt     DateTime?
  status         String   @default("ACTIVE")
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?

  assignment AuditAssignment @relation(fields: [assignmentId], references: [id])
  asset      Asset           @relation(fields: [assetId], references: [id])

  @@map("audit_items")
}

// ─── DISCREPANCY REPORTS ───────────────────────────────
model DiscrepancyReport {
  id          String   @id @default(uuid())
  cycleId     String
  assetId     String
  type        String   // MISSING, DAMAGED, LOCATION_MISMATCH, CONDITION_MISMATCH
  description String   @db.Text
  severity    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  resolution  String?  @db.Text
  isResolved  Boolean  @default(false)
  status      String   @default("ACTIVE")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  cycle AuditCycle @relation(fields: [cycleId], references: [id])
  asset Asset      @relation(fields: [assetId], references: [id])

  @@map("discrepancy_reports")
}

// ─── NOTIFICATIONS ─────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   // BOOKING, ALLOCATION, TRANSFER, MAINTENANCE, AUDIT, SYSTEM
  link      String?
  isRead    Boolean  @default(false)
  status    String   @default("ACTIVE")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── ACTIVITY LOGS ─────────────────────────────────────
model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  entity      String   // ASSET, USER, DEPARTMENT, etc.
  entityId    String?
  description String?  @db.Text
  oldValue    String?  @db.LongText
  newValue    String?  @db.LongText
  ipAddress   String?
  userAgent   String?  @db.Text
  status      String   @default("ACTIVE")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── SETTINGS ──────────────────────────────────────────
model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  group     String?  // GENERAL, EMAIL, NOTIFICATION, SYSTEM
  status    String   @default("ACTIVE")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@map("settings")
}
